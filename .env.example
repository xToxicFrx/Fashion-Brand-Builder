# =============================================================================
# Fashion Brand Builder — Environment Variables
# Copy this file to `.env` and fill in the values you have. The app boots and the
# Design Studio + database work with ONLY the Database + NextAuth vars set; the
# other integrations are lazy-loaded and only required when their feature is used.
# =============================================================================

# --- Database (PostgreSQL / Supabase) ---------------------------------------
# Supabase: Connect -> ORMs -> Prisma. Copy BOTH connection strings:
#   DATABASE_URL = Transaction pooler (port 6543) + ?pgbouncer=true — used by the app.
#   DIRECT_URL   = Session pooler (port 5432) — used by `prisma db push` at build.
# Replace PASSWORD with your DB password (letters/numbers only avoids URL-encoding).
DATABASE_URL="postgresql://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- Supabase Storage (optional: permanent mockup images) -------------------
# Mockups are generated with gpt-image-1 (falling back to dall-e-3/2). Without
# these vars the image can be previewed but not saved permanently — gpt-image-1
# returns inline data and dall-e URLs expire after ~1-2h. Set them to copy each
# mockup into a public Supabase Storage bucket so saved mockups keep working.
# SUPABASE_URL is your project URL; the service-role key (Supabase: Project
# Settings -> API) is server-side only and creates the bucket on first upload.
SUPABASE_URL="https://REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
# Bucket name to store mockups in (created automatically, public). Default: mockups
SUPABASE_STORAGE_BUCKET="mockups"

# --- NextAuth (required) -----------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-please-generate-a-real-secret"

# --- Google OAuth (optional: enables "Sign in with Google") ------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Anthropic Claude (trend analysis & design suggestions) ------------------
ANTHROPIC_API_KEY=""
CLAUDE_MODEL="claude-opus-4-8"

# --- OpenAI (trend insights, briefs & mockup image generation) ---------------
OPENAI_API_KEY=""
# Optional text model override (default: gpt-4o).
# OPENAI_MODEL="gpt-4o"
# Optional image model. Leave unset to auto-try gpt-image-1 -> dall-e-3 ->
# dall-e-2 (works with whichever your key has access to). Set to pin one, e.g.
# OPENAI_IMAGE_MODEL="gpt-image-1"

# --- Stripe (checkout & subscriptions) --------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Price IDs for the paid plans (Stripe -> Product catalog -> open a product ->
# the price's "price_..." ID). A plan with no price ID shows but isn't
# purchasable. The *_LABEL values are display-only (shown on the Plans page).
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_STARTER_LABEL="$9/mo"
STRIPE_PRICE_PRO_LABEL="$29/mo"
# Public base URL used to build Stripe success/cancel redirect URLs.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Resend (transactional email & trend alerts) ----------------------------
RESEND_API_KEY=""
EMAIL_FROM="Fashion Brand Builder <onboarding@resend.dev>"

# --- UploadThing (production image storage) ----------------------------------
# Local dev writes uploads to /public/uploads. For production, set these and
# swap /api/upload for an UploadThing route (see README).
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""
