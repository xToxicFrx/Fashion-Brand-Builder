# =============================================================================
# Fashion Brand Builder — Environment Variables
# Copy this file to `.env` and fill in the values you have. The app boots and the
# Design Studio + database work with ONLY the Database + NextAuth vars set; the
# other integrations are lazy-loaded and only required when their feature is used.
# =============================================================================

# --- Database (PostgreSQL / Supabase) ---------------------------------------
# Supabase: Connect -> ORMs -> Prisma. Copy BOTH connection strings:
#   DATABASE_URL = Transaction pooler (port 6543) + ?pgbouncer=true — used by the app.
#   DIRECT_URL   = Session pooler (port 5432) — used by `prisma db push` at build.
# Replace PASSWORD with your DB password (letters/numbers only avoids URL-encoding).
DATABASE_URL="postgresql://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- NextAuth (required) -----------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-please-generate-a-real-secret"

# --- Google OAuth (optional: enables "Sign in with Google") ------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Anthropic Claude (trend analysis & design suggestions) ------------------
ANTHROPIC_API_KEY=""
CLAUDE_MODEL="claude-opus-4-8"

# --- Stripe (checkout & subscriptions) --------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Public base URL used to build Stripe success/cancel redirect URLs.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Resend (transactional email & trend alerts) ----------------------------
RESEND_API_KEY=""
EMAIL_FROM="Fashion Brand Builder <onboarding@resend.dev>"

# --- UploadThing (production image storage) ----------------------------------
# Local dev writes uploads to /public/uploads. For production, set these and
# swap /api/upload for an UploadThing route (see README).
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""
