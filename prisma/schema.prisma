// Fashion Brand Builder — Prisma schema
// Database: PostgreSQL (Supabase in production). `url` (DATABASE_URL) is the
// Transaction pooler (port 6543, +?pgbouncer=true) used by the app at runtime;
// `directUrl` (DIRECT_URL) is the Session pooler (port 5432) used by `prisma db
// push` at build time (DDL needs a real session, not the pgbouncer pooler).
// Enum-like fields are modeled as String + validated with Zod (lib/validations.ts).
// JSON-shaped fields are stored as String (JSON-encoded) via lib/json.ts; on
// PostgreSQL they can optionally be migrated to Json/Jsonb later.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----------------------------------------------------------------------------
// NextAuth adapter models
// ----------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ----------------------------------------------------------------------------
// Domain models
// ----------------------------------------------------------------------------

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  image            String?
  hashedPassword   String?
  role             String    @default("designer") // designer | brand | customer | admin
  category         String    @default("fashion") // primary vertical: fashion | home | jewelry | pod | beauty
  subscriptionTier String    @default("free") // free | starter | pro
  stripeCustomerId String?
  bio              String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  designs        Design[]
  stores         Store[]
  reviews        Review[]
  collaborations Collaboration[]

  // Trend Radar (FashionTrend AI)
  trackedNiches TrackedNiche[]
  savedIdeas    SavedIdea[]
  savedReports  SavedReport[]
  collections   Collection[]
  notifications Notification[]
  onboarding    OnboardingProfile?
}

model Design {
  id               String   @id @default(cuid())
  userId           String
  name             String
  description      String?
  category         String   @default("tshirt") // tshirt | hoodie | jacket | ...
  designData       String // JSON-encoded Konva/Fabric canvas state
  mockupImageUrl   String?
  thumbnailUrl     String?
  price            Float    @default(29.99)
  trendScore       Int? // 0-100 (AI generated)
  demandPrediction Int? // estimated units 0-1000
  status           String   @default("draft") // draft | published | archived
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  products       Product[]
  reviews        Review[]
  collaborations Collaboration[]
  trends         Trend[]         @relation("DesignTrends")
}

model Product {
  id            String   @id @default(cuid())
  designId      String
  storeId       String
  sku           String   @unique
  sizes         String // JSON-encoded ["XS","S","M","L","XL","XXL"]
  prices        String // JSON-encoded { "M": 29.99, ... }
  inventory     String // JSON-encoded { "M": 100, ... }
  printProvider String? // printful | teespring | ...
  externalId    String?
  isPublished   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  design Design @relation(fields: [designId], references: [id], onDelete: Cascade)
  store  Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Store {
  id               String   @id @default(cuid())
  userId           String
  name             String
  slug             String   @unique
  description      String?
  logoUrl          String?
  brandColors      String? // JSON-encoded { primary, secondary, accent }
  customDomain     String?
  subscriptionTier String   @default("free")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
  orders   Order[]
}

model Order {
  id              String   @id @default(cuid())
  storeId         String
  customerEmail   String
  items           String // JSON-encoded [{ productId, quantity, price, size }]
  totalAmount     Float
  status          String   @default("pending") // pending | processing | shipped | delivered
  stripePaymentId String?
  shippingAddress String? // JSON-encoded shipping address
  trackingNumber  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Trend {
  id               String    @id @default(cuid())
  keyword          String
  category         String?
  trendScore       Int       @default(0) // 0-100
  googleTrendsData String? // JSON-encoded Google Trends payload
  tiktokEngagement Int?
  redditSentiment  Float?
  predictionStatus String    @default("trending_up") // trending_up | peak | declining
  generatedAt      DateTime  @default(now())
  expiresAt        DateTime?

  designs Design[] @relation("DesignTrends")
}

model Review {
  id        String   @id @default(cuid())
  designId  String
  userId    String
  rating    Int // 1-5
  comment   String?
  createdAt DateTime @default(now())

  design Design @relation(fields: [designId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Collaboration {
  id              String   @id @default(cuid())
  designId        String
  collaboratorId  String
  role            String   @default("contributor") // co-designer | contributor
  splitPercentage Float    @default(0)
  status          String   @default("pending") // pending | accepted | declined
  createdAt       DateTime @default(now())

  design       Design @relation(fields: [designId], references: [id], onDelete: Cascade)
  collaborator User   @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
}

// Landing-page waitlist: capture interest in the AI trend tool to gauge demand
// before building further. Standalone (no auth, no relations).
model WaitlistSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  sellsOn   String? // etsy | tiktok | instagram | own_store | nothing_yet
  source    String? // optional traffic-source tag (utm/referrer)
  createdAt DateTime @default(now())
}

// ----------------------------------------------------------------------------
// Trend Radar / FashionTrend AI
// ----------------------------------------------------------------------------

model TrackedNiche {
  id             String   @id @default(cuid())
  userId         String
  keyword        String
  category       String?
  alertThreshold Int? // notify when trendScore crosses this
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, keyword])
}

// Periodic snapshot of a keyword's trend score so we can show history + deltas.
model TrendSnapshot {
  id         String   @id @default(cuid())
  keyword    String
  trendScore Int
  momentum   String // trending_up | peak | declining
  source     String   @default("ai_estimate") // google_trends | ai_estimate
  dataJson   String // JSON-encoded report payload (timeline, related, etc.)
  createdAt  DateTime @default(now())

  @@index([keyword, createdAt])
}

model SavedIdea {
  id             String   @id @default(cuid())
  userId         String
  keyword        String
  title          String
  description    String?
  suggestedPrice Float?
  status         String   @default("idea") // idea | brief | designed | listed
  briefJson      String? // generated design brief (JSON)
  imageUrl       String? // AI concept image
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Collection {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?
  status      String    @default("planning") // planning | in_progress | launched
  launchDate  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CollectionItem[]
}

model CollectionItem {
  id           String   @id @default(cuid())
  collectionId String
  title        String
  keyword      String?
  status       String   @default("idea") // idea | designing | ready | listed
  notes        String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // alert | digest | system
  title     String
  body      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model OnboardingProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  category  String? // chosen vertical: fashion | home | jewelry | pod | beauty
  niches    String? // JSON array of niche keywords
  style     String?
  goals     String? // JSON array of goals
  brandName String?
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Full trend report saved per user for instant re-open (no AI cost). One per
// user+keyword (latest wins).
model SavedReport {
  id         String   @id @default(cuid())
  userId     String
  keyword    String
  trendScore Int
  momentum   String
  dataSource String
  reportJson String // full TrendReport JSON
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, keyword])
}

// Lightweight product analytics: one row per tracked user action. Powers the
// admin funnel/metrics view and (Phase C) usage metering. Intentionally
// decoupled from User (plain userId string, nullable) so pre-auth events can be
// recorded and a user deletion never cascades away the metrics history.
model Event {
  id        String   @id @default(cuid())
  userId    String? // null for anonymous / pre-auth events
  type      String // signup | onboarding_complete | report_generated | idea_saved | brief_generated | mockup_generated | paywall_hit | checkout_started | subscribed
  keyword   String? // optional context (e.g. the niche)
  meta      String? // optional JSON-encoded extra context
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([userId, createdAt])
}

// Durable, cross-user cache of computed trend reports so repeat lookups are
// instant and don't re-spend on Google Trends / OpenAI. Keyed by
// keyword|variant|geo (see getTrendReport). Survives serverless cold starts,
// unlike the per-instance in-memory cache. Additive; safe to drop/rebuild.
model ReportCache {
  id         String   @id @default(cuid())
  key        String   @unique
  reportJson String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([updatedAt])
}

// Durable, DB-backed rate-limit hits (no Redis needed). One row per allowed
// action; rateLimit() counts a key's recent rows and prunes expired ones.
model RateHit {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}
